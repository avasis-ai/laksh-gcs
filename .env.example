# Reactor platform — server-side secret. NEVER expose to the client.
# Get your key from https://reactor.inc/dashboard (keys start with rk_)
REACTOR_API_KEY=rk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Reactor API base (optional, defaults to https://api.reactor.inc)
REACTOR_API_URL=https://api.reactor.inc

# Default model for the dashboard (lingbot | helios | longlive-v2 | sana-streaming)
NEXT_PUBLIC_REACTOR_MODEL=lingbot
